root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{toml,yaml,yml,json}]
indent_style = space
indent_size = 2

[*.{md,markdown}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{html,css,scss,js,ts}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
